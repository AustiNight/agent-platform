# =============================================================================
# Agent Platform Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# -----------------------------------------------------------------------------
# LLM Provider API Keys
# -----------------------------------------------------------------------------
# At minimum, provide one of these. Anthropic recommended as primary.

ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=sk-your-key-here

# Local LLM (Ollama)
OLLAMA_BASE_URL=http://localhost:11434

# -----------------------------------------------------------------------------
# Default LLM Settings
# -----------------------------------------------------------------------------
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-sonnet-4-20250514

# For cost-sensitive tasks, you might use:
# DEFAULT_LLM_MODEL=claude-haiku-4-20250514

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Development: SQLite (no setup required)
DATABASE_URL=sqlite+aiosqlite:///./agent_platform.db

# Production: PostgreSQL
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/agent_platform

# -----------------------------------------------------------------------------
# Redis Configuration (Task Queue)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Browser Agent Settings
# -----------------------------------------------------------------------------
# Run browser in headed mode (visible window) for debugging
BROWSER_HEADLESS=false

# Default timeout for browser operations (seconds)
BROWSER_TIMEOUT=60

# Screenshot storage path
SCREENSHOT_DIR=./data/screenshots

# -----------------------------------------------------------------------------
# API Server Settings
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=change-me-in-production

# Optional: API key for authenticating requests
# API_AUTH_KEY=your-api-auth-key

# -----------------------------------------------------------------------------
# Site Credentials (for browser agent)
# -----------------------------------------------------------------------------
# Credentials are retrieved by domain. Use the pattern: SITE_domain_field
# Replace dots with underscores in domain names.
#
# Example for github.com:
# SITE_GITHUB_COM_USERNAME=your-github-username
# SITE_GITHUB_COM_PASSWORD=your-github-password
#
# Example for internal.company.com:
# SITE_INTERNAL_COMPANY_COM_USERNAME=user@company.com
# SITE_INTERNAL_COMPANY_COM_PASSWORD=secret123

# -----------------------------------------------------------------------------
# HashiCorp Vault (optional, for production secrets management)
# -----------------------------------------------------------------------------
# If configured, secrets will be fetched from Vault first, then fall back to env vars
# VAULT_ADDR=http://localhost:8200
# VAULT_TOKEN=your-vault-token
# VAULT_SECRET_PATH=secret/data/agent-platform

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=console  # console or json

# -----------------------------------------------------------------------------
# GEPA Automation Configuration
# -----------------------------------------------------------------------------
# Enable/disable automatic GEPA optimization
GEPA_AUTO_ENABLED=true

# Optimization triggers
GEPA_MIN_TRACES=50              # Minimum traces before optimization
GEPA_INTERVAL_HOURS=24          # Hours between optimizations
GEPA_PERF_DROP_THRESHOLD=0.15   # Performance drop % that triggers optimization
GEPA_BUDGET=medium              # light, medium, or heavy

# Notification: Email (primary - highly recommended)
GEPA_NOTIFY_EMAIL=your-email@example.com
GEPA_FROM_EMAIL=gepa-automation@agent-platform.local
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Notification: Slack (recommended for teams)
# GEPA_SLACK_WEBHOOK=https://hooks.slack.com/services/xxx/yyy/zzz

# Notification: Pushover (mobile push - recommended for critical alerts)
# PUSHOVER_USER_KEY=your-user-key
# PUSHOVER_API_TOKEN=your-api-token

# Notification: SMS via Twilio (for critical alerts)
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_FROM_NUMBER=+1234567890
# TWILIO_TO_NUMBER=+0987654321

# Notification: Generic webhook (for custom integrations)
# GEPA_WEBHOOK_URL=https://your-webhook-endpoint.com/gepa

# Advanced GEPA settings
# GEPA_AUTO_APPROVE_HEAVY=false  # Auto-approve expensive optimizations
# GEPA_RATE_LIMIT_DELAY=0        # Delay between API calls (seconds)
# GEPA_MAX_TRACES_PER_BATCH=50   # Max traces per optimization batch
# GEPA_TIMEOUT_SECONDS=300       # Timeout for optimization runs
# GEPA_DEBUG=false               # Enable debug logging

# -----------------------------------------------------------------------------
# Task Worker Settings
# -----------------------------------------------------------------------------
WORKER_CONCURRENCY=2
MAX_RETRIES=3
RETRY_DELAY_SECONDS=5
